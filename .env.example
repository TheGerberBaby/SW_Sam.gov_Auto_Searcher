# Only needed for the live-API script (find_contracts.py).
# The bulk scripts (sync_bulk.py + search_bulk.py) do NOT need a key.
#
# Get a key: sign in at https://sam.gov -> Account Details -> API Key
SAM_API_KEY=your_key_here

# Local Elasticsearch document index. compose.yaml exposes this only on localhost.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=stormwind_documents_v1

# Optional semantic retrieval. Leave disabled for text-only retrieval.
# When enabled, new document chunks receive embeddings and semantic/hybrid
# search is available.
EMBEDDING_PROVIDER=none
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Date/deadline filtering in the MCP research server.
USER_TIMEZONE=America/New_York
